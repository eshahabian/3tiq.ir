# کپی کن به .env و مقادیر را پر کن (این فایل را commit نکن)

# توکن دسترسی Meta — یک‌بار از developers.facebook.com بگیر (راهنما پایین)
META_ACCESS_TOKEN=

# شناسه اکانت اینستاگرام Business (با node tools/instagram-setup.mjs پیدا می‌شود)
INSTAGRAM_USER_ID=

# آدرس سایت — تصاویر باید از اینجا عمومی در دسترس باشند
SITE_URL=https://3tiq.ir

# اختیاری — نسخه Graph API
META_GRAPH_VERSION=v21.0
